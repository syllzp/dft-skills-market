&CONTROL
  calculation = 'relax'
  prefix      = 'water'
  outdir      = './tmp/'
  pseudo_dir  = './pseudo/'
  verbosity   = 'high'
  etot_conv_thr = 1.D-5
  forc_conv_thr = 1.D-4
/
&SYSTEM
  ibrav       = 0
  nat         = 3
  ntyp        = 2
  ecutwfc     = 40
  ecutrho     = 320
  occupations = 'smearing'
  smearing    = 'marzari-vanderbilt'
  degauss     = 0.01
  vdw_corr    = 'DFT-D3'
/
&ELECTRONS
  conv_thr         = 1.D-6
  mixing_beta      = 0.7
  mixing_mode      = 'local-TF'
  electron_maxstep = 200
/
&IONS
  ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
  O  15.999  O.pbe-n-kjpaw_psl.1.0.0.UPF
  H   1.008  H.pbe-kjpaw_psl.1.0.0.UPF
ATOMIC_POSITIONS {angstrom}
  O    0.000000    0.000000    0.117000
  H    0.757000    0.000000   -0.469000
  H   -0.757000    0.000000   -0.469000
K_POINTS {gamma}
