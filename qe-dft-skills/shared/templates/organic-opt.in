&CONTROL
  calculation = 'relax'
  prefix      = '<NAME>'
  outdir      = './tmp/'
  pseudo_dir  = './pseudo/'
  verbosity   = 'high'
  etot_conv_thr = 1.D-5
  forc_conv_thr = 1.D-4
/
&SYSTEM
  ibrav       = 0
  nat         = <N_ATOMS>
  ntyp        = <N_TYPES>
  ecutwfc     = <ECUTWFC>
  ecutrho     = <ECUTRHO>
  occupations = 'smearing'
  smearing    = 'marzari-vanderbilt'
  degauss     = 0.01
  vdw_corr    = 'DFT-D3'
/
&ELECTRONS
  conv_thr         = 1.D-6
  mixing_beta      = 0.7
  mixing_mode      = 'local-TF'
  electron_maxstep = 200
/
&IONS
  ion_dynamics = 'bfgs'
/
ATOMIC_SPECIES
 <TYPE1> <MASS1> <PSEUDO1>
 <TYPE2> <MASS2> <PSEUDO2>
 ...
ATOMIC_POSITIONS {angstrom}
 <ELEMENT> <X> <Y> <Z>
 ...
K_POINTS {gamma}
