&CONTROL
  calculation = 'scf'
  prefix      = '<NAME>'
  outdir      = './tmp/'
  pseudo_dir  = './pseudo/'
  verbosity   = 'high'
/
&SYSTEM
  ibrav       = <IBRAV>
  nat         = <N_ATOMS>
  ntyp        = <N_TYPES>
  ecutwfc     = <ECUTWFC>
  ecutrho     = <ECUTRHO>
  occupations = 'smearing'
  smearing    = 'marzari-vanderbilt'
  degauss     = 0.02
/
&ELECTRONS
  conv_thr         = 1.D-7
  mixing_beta      = 0.5
  mixing_mode      = 'plain'
  electron_maxstep = 200
  diago_thr_init   = 1.D-5
/
ATOMIC_SPECIES
<TYPES>
ATOMIC_POSITIONS {angstrom}
<POSITIONS>
K_POINTS {automatic}
<KPOINTS>
